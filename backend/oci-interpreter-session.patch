@@ -104,0 +133,32 @@
+function normalizeInterpreterLanguages(languages) {
+  if (!Array.isArray(languages) || languages.length !== 2) {
+    return null;
+  }
+
+  const normalized = languages.map(normalizeLanguage);
+  const uniqueLanguages = new Set(normalized);
+
+  if (
+    uniqueLanguages.size !== 2 ||
+    normalized.some((language) => !INTERPRETER_LANGUAGES.has(language))
+  ) {
+    return null;
+  }
+
+  return normalized;
+}
+
+function normalizeInterpreterMicrophoneProfile(profile) {
+  const normalized = String(
+    profile || OPENAI_INTERPRETER_NOISE_REDUCTION,
+  )
+    .trim()
+    .toLowerCase();
+
+  if (!INTERPRETER_MICROPHONE_PROFILES.has(normalized)) {
+    return null;
+  }
+
+  return normalized;
+}
