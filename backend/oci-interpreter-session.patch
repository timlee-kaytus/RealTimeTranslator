+app.post("/api/realtime/interpreter-session", async (req, res) => {
+  const { languages, microphoneProfile, clientId, uiSessionId } = req.body || {};
+  const normalizedLanguages = normalizeInterpreterLanguages(languages);
+
+  if (!normalizedLanguages) {
+    return res.status(400).json({
+      error: "invalid_interpreter_languages",
+      message: "languages must contain ko and zh exactly once.",
+    });
+  }
+
+  const normalizedMicrophoneProfile =
+    normalizeInterpreterMicrophoneProfile(microphoneProfile);
+
+  if (!normalizedMicrophoneProfile) {
+    return res.status(400).json({
+      error: "invalid_microphone_profile",
+      message: "microphoneProfile must be near_field or far_field.",
+    });
+  }
+
+  const sessionId = `rtti_${crypto.randomUUID()}`;
+
+  try {
+    const response = await createOpenAIInterpreterCredential({
+      sessionId,
+      languages: normalizedLanguages,
+      microphoneProfile: normalizedMicrophoneProfile,
+      clientId,
+      uiSessionId,
+    });
+
+    logSafe({
+      event: "interpreter_session_created",
+      sessionId,
+      languages: normalizedLanguages,
+      microphoneProfile: normalizedMicrophoneProfile,
+      model: response.model,
+      voice: response.voice,
+      timestamp: nowIso(),
+    });
+
+    return res.json(response);
+  } catch (error) {
+    const code = error.code || "interpreter_session_create_failed";
+    const openaiStatus = Number.isInteger(error.status) ? error.status : null;
+
+    logSafe({
+      event: "interpreter_session_create_failed",
+      sessionId,
+      code,
+      openaiStatus,
+      openaiRequestId: error.openaiRequestId || null,
+      responseKeys: error.responseKeys || null,
+      message: error instanceof Error ? error.message : String(error),
+      timestamp: nowIso(),
+    });
+
+    if (code === "missing_openai_api_key") {
+      return res.status(500).json({
+        error: code,
+        message: "OpenAI is not configured on the backend.",
+      });
+    }
+
+    if (code === "openai_interpreter_client_secret_failed") {
+      return res.status(openaiStatus === 429 ? 503 : 502).json({
+        error: code,
+        message: "Failed to create OpenAI realtime interpreter session.",
+      });
+    }
+
+    if (code === "openai_interpreter_client_secret_missing_value") {
+      return res.status(502).json({
+        error: code,
+        message: "OpenAI did not return interpreter session credentials.",
+      });
+    }
+
+    return res.status(500).json({
+      error: "interpreter_session_create_failed",
+      message: "Unexpected error while creating the interpreter session.",
+    });
+  }
+});
